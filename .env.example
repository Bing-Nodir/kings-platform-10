# Copy this file to `.env.local` and paste your real values there.
# PowerShell:
#   Copy-Item .env.example .env.local

# Required: Supabase public app connection
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Required for admin-only server operations and webhook processing
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Required for Prisma/Supabase Postgres via transaction pooling
DATABASE_URL="postgresql://postgres.your-project-ref:your_database_password@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Required for Prisma migrations and introspection on IPv4 networks
DIRECT_URL="postgresql://postgres.your-project-ref:your_database_password@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"

# Optional: Supabase direct database connection. This may require IPv6 or the Supabase IPv4 add-on.
DIRECT_DATABASE_URL_IPV6="postgresql://postgres:your_database_password@db.your-project-ref.supabase.co:5432/postgres"

# Required for AI Mentor
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: if empty, the app falls back to the default model in lib/server/env.ts
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Required in production if you use /api/payments/webhook/[provider]
PAYMENT_WEBHOOK_SHARED_SECRET=replace_with_a_long_random_secret

# Optional: only set true if you want manual sandbox payment confirmation enabled in production
ALLOW_SANDBOX_PAYMENT_CONFIRMATION=false

# Optional: health check timeout in milliseconds, allowed range 500-15000
BACKEND_HEALTH_TIMEOUT_MS=4000

# Notes from the current codebase analysis:
# - Real card / Payme / Click merchant API keys are not wired into the app yet.
# - Email delivery provider keys (for example Resend) are not used yet; emails are queued in the database.
